@model IEnumerable<CMS.Data.Entities.Post>
@{
    ViewData["Title"] = "Danh sách bài viết";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold m-0 text-uppercase" style="letter-spacing: 1px;">Danh Sách Bài Viết</h2>
        <a href="#" class="btn btn-success btn-sm px-3 py-2 fw-semibold">
            <i class="bi bi-plus-circle"></i> + Thêm bài viết mới
        </a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                        <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 200px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/350x200?text=No+Image'">

                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                @if (item.Category != null)
                                {
                                    <span class="badge bg-info text-dark px-2.5 py-1.5 fw-semibold">@item.Category.Name</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary text-white px-2.5 py-1.5">Không rõ danh mục</span>
                                }
                            </div>

                            <h5 class="card-title text-primary fw-bold mb-2 text-truncate" title="@item.Title">@item.Title</h5>

                            <p class="card-text text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                @item.Content
                            </p>

                            <p class="text-secondary small mb-3">
                                <i class="bi bi-calendar3"></i> Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                            </p>

                            <div class="d-flex gap-1 mt-auto">
                                <a asp-controller="Post" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm px-2">Xem chi tiết</a>
                                <a href="#" class="btn btn-outline-warning btn-sm px-2">Sửa</a>
                                <a href="#" class="btn btn-outline-danger btn-sm px-2">🗑 Xóa</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-warning text-center" role="alert">
                    Hệ thống chưa có bài viết nào được nạp dữ liệu.
                </div>
            </div>
        }
    </div>
</div>