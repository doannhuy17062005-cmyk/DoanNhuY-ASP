@model IEnumerable<CMS.Data.Entities.Post>
@* Khai báo View nhận danh sách bài viết *@

<div class="container mt-4">
    @* Khung chứa nội dung danh sách bài viết *@

    <h2 class="mb-4 text-danger">DANH SÁCH BÀI VIẾT MỚI NHẤT</h2>
    @* Tiêu đề trang *@

    <div class="row">
        @* Tạo hàng để hiển thị các bài viết dạng card *@

        @foreach (var item in Model)
        {
            @* Duyệt từng bài viết trong danh sách *@

            <div class="col-md-4 mb-3">
                @* Mỗi bài viết chiếm 4 cột trên màn hình medium trở lên *@

                <div class="card shadow-sm">
                    @* Khung card hiển thị bài viết *@

                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail">
                    @* Hiển thị ảnh đại diện bài viết *@

                    <div class="card-body">
                        @* Phần nội dung bên trong card *@

                        <h5 class="card-title text-primary">@item.Title</h5>
                        @* Hiển thị tiêu đề bài viết *@

                        <p class="card-text text-truncate">
                            @item.Content
                        </p>
                        @* Hiển thị nội dung tóm tắt bài viết *@

                        <p class="text-muted small">
                            Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                        </p>
                        @* Hiển thị ngày đăng bài viết *@

                        <a href="/Post/Details/@item.Id" class="btn btn-outline-primary btn-sm">
                            Xem chi tiết
                        </a>
                        @* Nút chuyển sang trang chi tiết bài viết *@
                    </div>
                </div>
            </div>
        }
    </div>
</div>