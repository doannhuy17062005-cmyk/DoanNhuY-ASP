﻿
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrangCMS-Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
            box-shadow: 2px 0 5px rgba(0,0,0,0.1);
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                display: block;
                padding: 12px 20px;
                transition: all 0.2s ease;
                font-weight: 500;
            }

                .sidebar a:hover {
                    background-color: #343a40;
                    color: #ffffff;
                    padding-left: 25px;
                }

            .sidebar i {
                margin-right: 10px;
                font-size: 1.1rem;
            }

        .menu-header {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #6c757d;
            padding: 15px 20px 5px 20px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 sidebar p-0 position-fixed start-0 top-0 bottom-0 overflow-auto">
                <div class="p-3 text-center border-bottom border-secondary bg-dark">
                    <h4 class="text-white m-0 fw-bold"><i class="bi bi-shield-lock-fill text-warning"></i> ThaiCMS Admin</h4>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="mt-3 text-light">
                            <div class="fw-bold">@User.FindFirst("FullName")?.Value</div>
                            <div class="small text-warning">(@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</div>
                        </div>
                        <div class="mt-2">
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-light btn-sm w-100">Đăng xuất</a>
                        </div>
                    }
                </div>

                <div class="mt-2">
                    <div class="menu-header">Hệ thống</div>
                    <a asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Bảng điều khiển
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="User" asp-action="Index">
                            <i class="bi bi-people"></i> Quản lý Thành viên
                        </a>
                    }

                    <div class="menu-header">Nội dung CMS</div>
                    <a asp-controller="Category" asp-action="Index">
                        <i class="bi bi-grid"></i> Quản lý Danh mục
                    </a>
                    <a asp-controller="Post" asp-action="Index">
                        <i class="bi bi-file-earmark-post"></i> Quản lý Bài viết
                    </a>

                    <div class="menu-header">Kinh doanh / Bán hàng</div>
                </div>
            </nav>

            <main class="col-md-9 col-lg-10 ms-sm-auto p-4 bg-light" style="min-height: 100vh;">
                <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                    <h5 class="m-0">@ViewData["Title"]</h5>
                </div>

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>